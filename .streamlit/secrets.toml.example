# =============================================================================
# secrets.toml.example
#
# This is a TEMPLATE only — do not fill in real keys here.
# Copy the contents below into Streamlit Cloud's "Secrets" box
# (App settings → Secrets) with your real keys filled in.
#
# This file itself is safe to commit to GitHub since it has no real secrets.
# The actual .streamlit/secrets.toml (with real keys) is git-ignored and
# only used for local testing if you want st.secrets to work locally too.
# =============================================================================

VIRUSTOTAL_API_KEY = "paste_your_virustotal_key_here"
ABUSEIPDB_API_KEY  = "paste_your_abuseipdb_key_here"
